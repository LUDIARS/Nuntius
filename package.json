{
  "name": "nuntius",
  "version": "0.1.0",
  "description": "LUDIARS 統合通知・メッセージング基盤 (SQS/SNS 的)",
  "type": "module",
  "main": "dist/src/index.js",
  "scripts": {
    "dev": "npm run env:env && npx dotenv-cli -- concurrently -n api,worker -c cyan,green \"tsx watch src/index.ts\" \"tsx watch src/worker.ts\"",
    "dev:api": "tsx watch src/index.ts",
    "dev:worker": "tsx watch src/worker.ts",
    "build": "tsc",
    "start": "node dist/src/index.js",
    "start:worker": "node dist/src/worker.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "ci-check": "bash scripts/ci-check.sh",
    "env:setup": "npx tsx ../Cernere/packages/env-cli/src/cli.ts setup",
    "env:test": "npx tsx ../Cernere/packages/env-cli/src/cli.ts test",
    "env:env": "npx tsx ../Cernere/packages/env-cli/src/cli.ts env",
    "env:initialize": "npx tsx ../Cernere/packages/env-cli/src/cli.ts initialize",
    "env:list": "npx tsx ../Cernere/packages/env-cli/src/cli.ts list",
    "env:get": "npx tsx ../Cernere/packages/env-cli/src/cli.ts get",
    "env:set": "npx tsx ../Cernere/packages/env-cli/src/cli.ts set",
    "env:up": "npx tsx ../Cernere/packages/env-cli/src/cli.ts env && docker compose up -d",
    "env:up:standalone": "npx tsx ../Cernere/packages/env-cli/src/cli.ts env && docker compose -f docker-compose.yaml -f docker-compose.standalone.yaml up -d",
    "db:generate": "drizzle-kit generate",
    "db:push": "drizzle-kit push",
    "db:migrate": "drizzle-kit migrate"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/LUDIARS/Nuntius.git"
  },
  "dependencies": {
    "@aws-sdk/client-sns": "^3.700.0",
    "@hono/node-server": "^1.19.0",
    "@hono/node-ws": "^1.3.0",
    "bullmq": "^5.31.0",
    "cron-parser": "^4.9.0",
    "drizzle-orm": "^0.45.1",
    "hono": "^4.12.8",
    "ioredis": "^5.10.0",
    "jsonwebtoken": "^9.0.3",
    "nodemailer": "^6.9.18",
    "postgres": "^3.4.8",
    "uuid": "^13.0.0",
    "ws": "^8.20.0"
  },
  "devDependencies": {
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^22.0.0",
    "@types/nodemailer": "^6.4.17",
    "@types/uuid": "^10.0.0",
    "@types/ws": "^8.18.0",
    "concurrently": "^9.2.0",
    "dotenv-cli": "^11.0.0",
    "drizzle-kit": "^0.31.9",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.1.0"
  }
}
